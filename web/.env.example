# Nenhuma dessas é obrigatória pra rodar em dev — cada integração tem fallback (ver README.md).
# Copie pra .env.local e preencha só o que fizer sentido pro seu ambiente.
# Variáveis fora daqui (Stripe, storage S3/R2, DATABASE_URL etc.) existem no código como
# redundância/fallback opcional e não são necessárias pra operar com Mercado Pago + SuperFrete.

# URL pública do app — usada nos links de e-mail e no notification_url do webhook do Mercado Pago.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# lista separada por vírgula — promove a role:admin no primeiro login
ADMIN_EMAILS=

# --- Pagamento: Mercado Pago (gateway principal) ---
# Sandbox: credenciais de TESTE do painel MP (Suas integrações > Credenciais de teste, começam com TEST-).
MERCADOPAGO_ACCESS_TOKEN=
# Secret do webhook (painel MP > Webhooks) — sem ela, webhook recusa tudo em produção.
MERCADOPAGO_WEBHOOK_SECRET=

# --- Frete: SuperFrete ---
# Sandbox: token de homologação do painel SuperFrete.
SUPERFRETE_TOKEN=
SUPERFRETE_SANDBOX=true
STORE_ORIGIN_CEP=
# Remetente completo — exigido pela SuperFrete só na hora de GERAR ETIQUETA (não na cotação).
STORE_ORIGIN_NAME=
STORE_ORIGIN_ADDRESS=
STORE_ORIGIN_NUMBER=
STORE_ORIGIN_COMPLEMENT=
STORE_ORIGIN_DISTRICT=
STORE_ORIGIN_CITY=
STORE_ORIGIN_STATE=
# CPF ou CNPJ de quem envia (sem pontuação)
STORE_ORIGIN_DOCUMENT=

# --- E-mail transacional (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=pedidos@potinho.pet
# quem recebe notificação de novo pedido pago / estorno
LOJISTA_EMAIL=
